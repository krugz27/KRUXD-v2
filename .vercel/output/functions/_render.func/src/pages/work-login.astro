---
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';
import { normalizeWorkNextPath } from '../lib/workAuth';

const nextPath = normalizeWorkNextPath(Astro.url.searchParams.get('next'));
const errorParam = Astro.url.searchParams.get('error');
const hasIncorrectPasswordError = errorParam === 'incorrect';
const hasMissingPasswordConfigError = errorParam === 'missing-password-config';
const hasMissingSecretConfigError = errorParam === 'missing-secret-config';
---

<BaseLayout title="Work Access | KRUXD" currentPath="/work">
  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <a href="/">Home</a>
    <span class="crumb-sep" aria-hidden="true">/</span>
    <span aria-current="page">Work Access</span>
  </nav>

  <section class="hero compact">
    <p class="eyebrow">Protected Work</p>
    <h1>Enter Password</h1>
    <p>Featured work summaries remain public. Full Work pages require a password.</p>
  </section>

  <section class="section detail">
    <form class="work-login-form" method="post" action="/api/work-auth/login">
      <input type="hidden" name="next" value={nextPath} />

      <label class="work-login-label" for="work-password">Work Password</label>
      <input
        id="work-password"
        class="work-login-input"
        type="password"
        name="password"
        autocomplete="current-password"
        required
      />

      {
        hasIncorrectPasswordError && (
          <p class="work-login-error" role="alert">
            Incorrect password. Try again.
          </p>
        )
      }
      {
        hasMissingPasswordConfigError && (
          <p class="work-login-error" role="alert">
            Password protection is not configured yet. Set `WORK_SECTION_PASSWORD` and restart `npm run dev`.
          </p>
        )
      }
      {
        hasMissingSecretConfigError && (
          <p class="work-login-error" role="alert">
            Password secret is not configured. Set `WORK_SECTION_SECRET` (or rely on `WORK_SECTION_PASSWORD`) and restart `npm run dev`.
          </p>
        )
      }

      <div class="work-login-actions">
        <button type="submit" class="work-login-submit">Unlock Work</button>
        <a href="/" class="work-login-cancel">Back Home</a>
      </div>
    </form>
  </section>
</BaseLayout>

<style>
  .work-login-form {
    max-width: 34rem;
    display: grid;
    gap: 0.75rem;
  }

  .work-login-label {
    font-family: 'DotGothic16', monospace;
    font-size: 0.95rem;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: #3d2d22;
  }

  .work-login-input {
    width: 100%;
    min-height: 2.8rem;
    padding: 0.55rem 0.7rem;
    border: 2px solid #5d4a40;
    background: rgba(246, 239, 224, 0.86);
    color: #1f1712;
    font: inherit;
    box-shadow: inset 0 0 0 1px rgba(255, 232, 190, 0.65);
  }

  .work-login-input:focus {
    outline: 2px solid rgba(218, 160, 46, 0.75);
    outline-offset: 2px;
  }

  .work-login-error {
    margin: 0;
    color: #8e2e18;
    font-weight: 600;
  }

  .work-login-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    align-items: center;
  }

  .work-login-submit,
  .work-login-cancel {
    min-height: 2.5rem;
    padding: 0.45rem 0.75rem;
    border: 2px solid #291d17;
    background: linear-gradient(180deg, #3e3335 0%, #2c2324 60%, #1d1719 100%);
    color: #f7d69a;
    text-decoration: none;
    font-family: 'Literata', serif;
    font-size: 0.95rem;
    font-weight: 600;
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    cursor: pointer;
    box-shadow:
      inset 0 0 0 1px rgba(255, 228, 166, 0.22),
      inset 0 0 0 3px rgba(0, 0, 0, 0.2);
  }

  .work-login-submit:hover,
  .work-login-cancel:hover {
    background: linear-gradient(180deg, #4e3d2f 0%, #342821 58%, #231b17 100%);
    color: #ffefbe;
  }
</style>
