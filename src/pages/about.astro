---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About Me | KRUXD" currentPath="/about">
  <section class="hero compact">
    <p class="eyebrow">About</p>
    <h1>About Me</h1>
    <p>
      I’m a UX designer focused on designing products that balance user needs,
      business goals, and technical realities.
    </p>
  </section>

  <section class="section two-col">
    <article>
      <h2>My Approach</h2>
      <p>
        I combine qualitative research, interaction design, and systems thinking
        to create experiences that feel intuitive and dependable. My process is
        collaborative, evidence-driven, and grounded in clear problem framing.
      </p>
    </article>
    <article>
      <h2>What I Bring</h2>
      <ul class="plain-list">
        <li>UX strategy and roadmap alignment</li>
        <li>Information architecture and interaction design</li>
        <li>Usability testing and iterative prototyping</li>
        <li>Design system contribution and cross-functional delivery</li>
      </ul>
    </article>
  </section>
</BaseLayout>
