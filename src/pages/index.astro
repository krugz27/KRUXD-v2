---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const caseStudies = (await getCollection('caseStudies'))
  .sort((a, b) => b.data.year - a.data.year)
  .filter((entry) => entry.data.featured)
  .slice(0, 3);

const topMusings = (await getCollection('musings'))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 3);

const dateFormatter = new Intl.DateTimeFormat('en-US', {
  month: 'short',
  year: 'numeric'
});
---

<BaseLayout title="KRUXD | UX Design Portfolio" currentPath="/">
  <section class="hero hero-home">
    <img class="hero-portrait" src="/images/8-pixel-me.png" alt="KRUXD portrait" />
    <div class="hero-copy">
      <p class="eyebrow">Adam Krueger - Design Leader</p>
      <h1>From Signals to Systems: Designing Intelligent Products at Scale</h1>
      <p>
        I design products that need to hold up under scale, complexity, and scrutiny. That means thinking
        beyond flows and features to the systems, patterns, and decisions that shape how a product evolves.
      </p>
      <p>
        I’m drawn to ambiguous spaces where direction is still forming. I help teams clarify intent, align
        around what matters, and build experiences that feel inevitable in hindsight.
      </p>
      <p>
        I care about craft, but I care more about coherence. The goal is not just to ship something good,
        but to raise the quality bar in a way that lasts.
      </p>
      <p>Still curious. Still refining. Always aiming for better judgment.</p>
    </div>
  </section>

  <section class="section">
    <div class="section-head">
      <h2>Featured Case Studies</h2>
      <a href="/case-studies">View all</a>
    </div>
    <div class="card-grid">
      {
        caseStudies.map((entry) => (
          <article class="card">
            <a class="thumb-link" href={`/case-studies/${entry.slug}`} aria-label={`Open ${entry.data.title}`}>
              <img
                class="thumb"
                src={entry.data.thumbnail ?? '/images/placeholder-thumb.svg'}
                alt={`${entry.data.title} thumbnail`}
                loading="lazy"
                decoding="async"
              />
            </a>
            <p class="meta">{entry.data.industry} · {entry.data.category}</p>
            <h3>
              <a class="card-link" href={`/case-studies/${entry.slug}`}>
                {entry.data.title}
              </a>
            </h3>
            <p>{entry.data.summary}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="section">
    <div class="section-head">
      <h2>Top 3 Musings</h2>
      <a href="/musings">Read all</a>
    </div>
    <div class="list-stack">
      {
        topMusings.map((entry) => (
          <article class="list-item home-musing-item">
            <a class="thumb-link" href={`/musings/${entry.slug}`} aria-label={`Open ${entry.data.title}`}>
              <img
                class="thumb"
                src={entry.data.thumbnail ?? '/images/placeholder-thumb.svg'}
                alt={`${entry.data.title} thumbnail`}
                loading="lazy"
                decoding="async"
              />
            </a>
            <p class="meta">{dateFormatter.format(entry.data.publishDate)} · {entry.data.topic}</p>
            <h3>
              <a class="list-link" href={`/musings/${entry.slug}`}>
                {entry.data.title}
              </a>
            </h3>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>
