---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const caseStudies = (await getCollection('caseStudies'))
  .sort((a, b) => b.data.year - a.data.year)
  .filter((entry) => entry.data.featured)
  .slice(0, 3);

const topMusings = (await getCollection('musings'))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 3);

const dateFormatter = new Intl.DateTimeFormat('en-US', {
  month: 'short',
  year: 'numeric'
});
---

<BaseLayout title="KRUXD | UX Design Portfolio" currentPath="/">
  <section class="hero hero-home">
    <img class="hero-portrait" src="/images/8-pixel-me.png" alt="KRUXD portrait" />
    <div class="hero-copy">
      <p class="eyebrow">UX Designer Portfolio</p>
      <h1>Designing useful, clear, and human digital experiences.</h1>
      <p>
        I partner with product teams to turn ambiguity into thoughtful interfaces,
        tested workflows, and measurable outcomes.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="section-head">
      <h2>Featured Case Studies</h2>
      <a href="/case-studies">View all</a>
    </div>
    <div class="card-grid">
      {
        caseStudies.map((entry) => (
          <article class="card">
            <img
              class="thumb"
              src={entry.data.thumbnail ?? '/images/placeholder-thumb.svg'}
              alt={`${entry.data.title} thumbnail`}
              loading="lazy"
              decoding="async"
            />
            <p class="meta">{entry.data.industry} · {entry.data.category}</p>
            <h3>
              <a class="card-link" href={`/case-studies/${entry.slug}`}>
                {entry.data.title}
              </a>
            </h3>
            <p>{entry.data.summary}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="section">
    <div class="section-head">
      <h2>Top 3 Musings</h2>
      <a href="/musings">Read all</a>
    </div>
    <div class="list-stack">
      {
        topMusings.map((entry) => (
          <article class="list-item home-musing-item">
            <img
              class="thumb"
              src={entry.data.thumbnail ?? '/images/placeholder-thumb.svg'}
              alt={`${entry.data.title} thumbnail`}
              loading="lazy"
              decoding="async"
            />
            <p class="meta">{dateFormatter.format(entry.data.publishDate)} · {entry.data.topic}</p>
            <h3>
              <a class="list-link" href={`/musings/${entry.slug}`}>
                {entry.data.title}
              </a>
            </h3>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>
