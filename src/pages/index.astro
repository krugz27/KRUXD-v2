---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const workEntries = (await getCollection('work'))
  .sort((a, b) => b.data.year - a.data.year)
  .filter((entry) => entry.data.featured)
  .slice(0, 3);

const topMusings = (await getCollection('musings'))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 3);

const dateFormatter = new Intl.DateTimeFormat('en-US', {
  month: 'short',
  year: 'numeric'
});
---

<BaseLayout title="KRUXD | UX Design Portfolio" currentPath="/">
  <section class="hero hero-home">
    <img class="hero-portrait" src="/images/8-bit-me.png" alt="KRUXD portrait" />
    <div class="hero-copy">
      <p class="eyebrow">Let me introduce myself</p>
      <h1>I'm Adam Krueger,<br/> UX and Product Designer</h1>
      <p>
        With over 20 years of experience spanning design, strategy, and leadership, I help teams build products that hold up at scale. I've led global teams, bridged design and engineering, and mentored designers at every level, always thinking beyond flows and features to the systems and decisions that shape how a product evolves.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="section-head">
      <h2>Featured Work</h2>
      <a href="/work">View all</a>
    </div>
    <div class="card-grid">
      {
        workEntries.map((entry) => (
          <article class="card">
            <a class="thumb-link" href={`/work/${entry.slug}`} aria-label={`Open ${entry.data.title}`}>
              <img
                class="thumb"
                src={entry.data.thumbnail ?? '/images/placeholder-thumb.svg'}
                alt={`${entry.data.title} thumbnail`}
                loading="lazy"
                decoding="async"
              />
            </a>
            <p class="meta">{entry.data.industry} · {entry.data.category}</p>
            <h3>
              <a class="card-link" href={`/work/${entry.slug}`}>
                {entry.data.title}
              </a>
            </h3>
            <p>{entry.data.summary}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="section">
    <div class="section-head">
      <h2>Top 3 Musings</h2>
      <a href="/musings">Read all</a>
    </div>
    <div class="list-stack">
      {
        topMusings.map((entry) => (
          <article class="list-item home-musing-item">
            <a class="thumb-link" href={`/musings/${entry.slug}`} aria-label={`Open ${entry.data.title}`}>
              <img
                class="thumb"
                src={entry.data.thumbnail ?? '/images/placeholder-thumb.svg'}
                alt={`${entry.data.title} thumbnail`}
                loading="lazy"
                decoding="async"
              />
            </a>
            <p class="meta">{dateFormatter.format(entry.data.publishDate)} · {entry.data.topic}</p>
            <h3>
              <a class="list-link" href={`/musings/${entry.slug}`}>
                {entry.data.title}
              </a>
            </h3>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>
