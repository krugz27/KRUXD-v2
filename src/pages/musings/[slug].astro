---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const entries = await getCollection('musings');

  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry }
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const dateFormatter = new Intl.DateTimeFormat('en-US', {
  month: 'short',
  day: '2-digit',
  year: 'numeric'
});
---

<BaseLayout title={`${entry.data.title} | Musings | KRUXD`} currentPath="/musings">
  <article class="section detail">
    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span class="crumb-sep" aria-hidden="true">/</span>
      <a href="/musings">Musings</a>
      <span class="crumb-sep" aria-hidden="true">/</span>
      <span aria-current="page">{entry.data.title}</span>
    </nav>

    <p class="meta">{dateFormatter.format(entry.data.publishDate)} · {entry.data.topic}</p>
    <h1>{entry.data.title}</h1>
    <p class="lead">{entry.data.summary}</p>
    <div class="prose">
      <Content />
    </div>
  </article>
</BaseLayout>
