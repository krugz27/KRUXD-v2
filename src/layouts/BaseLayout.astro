---
import '../styles/global.css';

interface Props {
  title: string;
  currentPath: string;
}

const { title, currentPath } = Astro.props;

const isActive = (path: string) => currentPath === path;
const navItems = [
  { href: '/', icon: 'home', label: 'Home' },
  { href: '/work', icon: 'book_2', label: 'Work' },
  { href: '/experiments', icon: 'experiment', label: 'Experiments' },
  { href: '/musings', icon: 'cognition', label: 'Musings' },
  { href: '/about', icon: 'emoji_people', label: 'About Me' }
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body class="theme-vintage">
    <header class="site-header">
      <a class="brand-wrap" href="/" aria-label="KRUXD Home">
        <img class="brand-shield" src="/images/KRUXD-Shield.png" alt="KRUXD shield" />
        <span class="brand-lockup">
          <span class="brand">KRUXD</span>
          <span class="brand-subtitle">UX &amp; Product Design</span>
        </span>
      </a>
      <nav class="primary-nav" aria-label="Primary">
        <ul class="nav-links nav-inline">
          {
            navItems.map((item) => (
              <li>
                <a href={item.href} class={isActive(item.href) ? 'active' : ''}>
                  <span class="material-symbols-outlined nav-icon" aria-hidden="true">{item.icon}</span>
                  <span>{item.label}</span>
                </a>
              </li>
            ))
          }
        </ul>

        <div class="nav-menu">
          <button
            id="nav-menu-trigger"
            class="nav-menu-trigger"
            type="button"
            aria-expanded="false"
            aria-haspopup="menu"
            aria-controls="nav-menu-panel"
            aria-label="Open navigation menu"
          >
            <span class="material-symbols-outlined nav-icon" aria-hidden="true">menu</span>
            <span>Menu</span>
          </button>
          <div id="nav-menu-panel" class="nav-menu-panel" hidden>
            <div class="nav-menu-head">
              <span class="nav-menu-title">Menu</span>
              <div
                id="nav-menu-close"
                class="nav-menu-close"
                role="button"
                tabindex="0"
                aria-label="Close navigation menu"
              >
                <span class="material-symbols-outlined nav-icon" aria-hidden="true">close</span>
              </div>
            </div>
            <ul class="nav-menu-list" role="menu">
              {
                navItems.map((item) => (
                  <li>
                    <a href={item.href} class={isActive(item.href) ? 'active' : ''} role="menuitem">
                      <span class="material-symbols-outlined nav-icon" aria-hidden="true">{item.icon}</span>
                      <span>{item.label}</span>
                    </a>
                  </li>
                ))
              }
            </ul>
          </div>
        </div>
      </nav>
    </header>

    <main>
      <slot />
    </main>
    <div class="scroll-bg-mobile" aria-hidden="true"></div>
    <div class="panorama-bg" aria-hidden="true"></div>
    <div id="panorama-overlay" class="panorama-overlay" aria-hidden="true"></div>
    <div id="image-lightbox" class="image-lightbox" hidden aria-hidden="true">
      <button
        id="image-lightbox-close"
        class="image-lightbox-close"
        type="button"
        aria-label="Close image preview"
      >
        <span class="material-symbols-outlined nav-icon" aria-hidden="true">close</span>
      </button>
      <figure class="image-lightbox-figure">
        <img id="image-lightbox-img" class="image-lightbox-img" alt="" />
        <figcaption id="image-lightbox-caption" class="image-lightbox-caption"></figcaption>
      </figure>
    </div>
    <script>
      const BACKGROUND_ZOOM = 1.5;
      const PAN_SPEED = 0.18;
      const mobileScrollBg = document.querySelector('.scroll-bg-mobile');
      let headerIsCompact = false;
      const getHeaderCompactThreshold = () => (window.innerWidth <= 760 ? 20 : 56);

      const updateHeaderState = () => {
        const shouldBeCompact = window.scrollY > getHeaderCompactThreshold();
        if (shouldBeCompact === headerIsCompact) return;
        headerIsCompact = shouldBeCompact;
        document.body.classList.toggle('header-compact', shouldBeCompact);
      };

      const updateBackgroundPan = () => {
        const isMobileViewport = window.innerWidth <= 760;
        const effectiveSpeed = isMobileViewport ? 0.07 : PAN_SPEED;
        const effectiveZoom = isMobileViewport ? 1.2 : BACKGROUND_ZOOM;
        const fallbackTravel = Math.max(0, (effectiveZoom - 1) * window.innerWidth - 2);
        const mobileLayerTravel =
          isMobileViewport && mobileScrollBg instanceof HTMLElement
            ? (() => {
                const styles = window.getComputedStyle(mobileScrollBg);
                const leftPx = Number.parseFloat(styles.left || '0') || 0;
                const rightOverhang = mobileScrollBg.offsetWidth + leftPx - window.innerWidth;
                return Math.max(0, rightOverhang);
              })()
            : null;
        const maxPan = mobileLayerTravel ?? fallbackTravel;
        const pan = -Math.min(window.scrollY * effectiveSpeed, maxPan);
        document.body.style.setProperty('--bg-pan-x', `${pan}px`);
      };

      updateBackgroundPan();
      updateHeaderState();
      window.addEventListener(
        'scroll',
        () => {
          updateBackgroundPan();
          updateHeaderState();
        },
        { passive: true }
      );
      window.addEventListener('resize', updateBackgroundPan);

      const panoramaToggle = document.getElementById('panorama-toggle');
      const panoramaOverlay = document.getElementById('panorama-overlay');
      const navMenuTrigger = document.getElementById('nav-menu-trigger');
      const navMenuPanel = document.getElementById('nav-menu-panel');
      const navMenuClose = document.getElementById('nav-menu-close');
      const mainElement = document.querySelector('main');
      const imageLightbox = document.getElementById('image-lightbox');
      const imageLightboxImg = document.getElementById('image-lightbox-img');
      const imageLightboxCaption = document.getElementById('image-lightbox-caption');
      const imageLightboxClose = document.getElementById('image-lightbox-close');
      const heroPortrait = document.querySelector('.hero-portrait');
      const desktopHoverMedia = window.matchMedia('(hover: hover) and (pointer: fine)');
      const defaultPortraitSrc =
        heroPortrait instanceof HTMLImageElement ? heroPortrait.getAttribute('src') : null;
      const hoverPortraitSrc = '/images/8-bit-me-looking.png';

      const closeNavMenu = () => {
        if (!navMenuTrigger || !navMenuPanel) return;
        navMenuPanel.hidden = true;
        navMenuTrigger.setAttribute('aria-expanded', 'false');
      };

      const openNavMenu = () => {
        if (!navMenuTrigger || !navMenuPanel) return;
        navMenuPanel.hidden = false;
        navMenuTrigger.setAttribute('aria-expanded', 'true');
      };

      const closeImageLightbox = () => {
        if (
          !(imageLightbox instanceof HTMLElement) ||
          !(imageLightboxImg instanceof HTMLImageElement) ||
          !(imageLightboxCaption instanceof HTMLElement)
        ) {
          return;
        }
        imageLightbox.hidden = true;
        imageLightbox.setAttribute('aria-hidden', 'true');
        imageLightboxImg.removeAttribute('src');
        imageLightboxImg.alt = '';
        imageLightboxCaption.textContent = '';
        document.body.classList.remove('lightbox-open');
      };

      const openImageLightbox = (sourceImg) => {
        if (
          !(sourceImg instanceof HTMLImageElement) ||
          !(imageLightbox instanceof HTMLElement) ||
          !(imageLightboxImg instanceof HTMLImageElement) ||
          !(imageLightboxCaption instanceof HTMLElement)
        ) {
          return;
        }

        const src = sourceImg.currentSrc || sourceImg.src;
        if (!src) return;

        imageLightboxImg.src = src;
        imageLightboxImg.alt = sourceImg.alt || '';
        imageLightboxCaption.textContent = sourceImg.alt || '';
        imageLightbox.hidden = false;
        imageLightbox.setAttribute('aria-hidden', 'false');
        document.body.classList.add('lightbox-open');
      };

      if (navMenuTrigger && navMenuPanel) {
        navMenuTrigger.addEventListener('click', () => {
          const isOpen = navMenuTrigger.getAttribute('aria-expanded') === 'true';
          if (isOpen) {
            closeNavMenu();
            return;
          }
          openNavMenu();
        });

        document.addEventListener('click', (event) => {
          if (!(event.target instanceof Node)) return;
          const clickedOutsideMenu =
            !navMenuPanel.contains(event.target) && !navMenuTrigger.contains(event.target);
          if (clickedOutsideMenu) closeNavMenu();
        });

        navMenuPanel.querySelectorAll('a').forEach((link) => {
          link.addEventListener('click', () => {
            closeNavMenu();
          });
        });

        navMenuClose?.addEventListener('click', () => {
          closeNavMenu();
        });

        navMenuClose?.addEventListener('keydown', (event) => {
          if (event.key === 'Enter' || event.key === ' ') {
            event.preventDefault();
            closeNavMenu();
          }
        });

        window.addEventListener('resize', () => {
          if (window.innerWidth > 1160) closeNavMenu();
        });
      }

      if (heroPortrait instanceof HTMLImageElement && defaultPortraitSrc) {
        const navHoverTargets = Array.from(document.querySelectorAll('.nav-inline a'));
        const setPortraitHoverState = (isHovered) => {
          if (!desktopHoverMedia.matches || window.innerWidth <= 760) return;
          heroPortrait.src = isHovered ? hoverPortraitSrc : defaultPortraitSrc;
        };

        navHoverTargets.forEach((link) => {
          link.addEventListener('mouseenter', () => setPortraitHoverState(true));
          link.addEventListener('mouseleave', () => setPortraitHoverState(false));
          link.addEventListener('focus', () => setPortraitHoverState(true));
          link.addEventListener('blur', () => setPortraitHoverState(false));
        });

        window.addEventListener('resize', () => {
          if (!desktopHoverMedia.matches || window.innerWidth <= 760) {
            heroPortrait.src = defaultPortraitSrc;
          }
        });
      }

      if (mainElement) {
        mainElement.addEventListener('click', (event) => {
          if (!(event.target instanceof Element)) return;
          const proseImage = event.target.closest('.prose img, .detail-gallery-thumb img');
          if (proseImage instanceof HTMLImageElement) {
            const wrappedLink = proseImage.closest('a');
            if (wrappedLink instanceof HTMLAnchorElement) {
              event.preventDefault();
            }
            openImageLightbox(proseImage);
            return;
          }
          if (event.target.closest('a, button, input, textarea, select, summary')) return;
          const card = event.target.closest('.card, .list-item');
          if (!card) return;
          const primaryLink = card.querySelector('.thumb-link, .card-link, .list-link');
          if (!(primaryLink instanceof HTMLAnchorElement)) return;
          if (window.getSelection()?.toString()) return;
          window.location.href = primaryLink.href;
        });
      }

      imageLightboxClose?.addEventListener('click', () => {
        closeImageLightbox();
      });

      imageLightbox?.addEventListener('click', (event) => {
        if (!(event.target instanceof Element)) return;
        if (event.target.closest('.image-lightbox-figure, #image-lightbox-close')) return;
        closeImageLightbox();
      });

      document.addEventListener('keydown', (event) => {
        if (event.key !== 'Escape') return;
        closeNavMenu();
        closeImageLightbox();
        if (document.body.classList.contains('panoramic-mode')) {
          document.body.classList.remove('panoramic-mode');
        }
      });

      if (panoramaToggle && panoramaOverlay) {
        const enterPanorama = () => {
          document.body.classList.add('panoramic-mode');
        };

        const exitPanorama = () => {
          document.body.classList.remove('panoramic-mode');
        };

        panoramaToggle.addEventListener('click', (event) => {
          event.preventDefault();
          event.stopPropagation();
          if (document.body.classList.contains('panoramic-mode')) {
            exitPanorama();
            return;
          }
          enterPanorama();
        });

        panoramaOverlay.addEventListener('click', () => {
          exitPanorama();
        });
      }
    </script>
  </body>
</html>
